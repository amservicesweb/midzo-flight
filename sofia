<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Midzo Flight · Sofia, votre conseillère voyage IA</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Plus Jakarta Sans',sans-serif;background:#f1f7ff;color:#111236;-webkit-font-smoothing:antialiased;min-height:100vh}
.top-bar{background:#fff;border-bottom:1px solid #e6e6e6;padding:0.75rem 1.5rem;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.top-bar a{text-decoration:none;color:#0770e3;font-weight:700;font-size:0.9rem;display:flex;align-items:center;gap:6px}
.top-bar a:hover{text-decoration:underline}
.chat-container{max-width:720px;margin:2rem auto;background:#fff;border-radius:16px;border:1px solid #e6e6e6;overflow:hidden;box-shadow:0 4px 24px rgba(7,112,227,.08)}
.chat-header{background:linear-gradient(135deg,#0a1840,#0c2775);padding:1.2rem 1.5rem;display:flex;align-items:center;gap:1rem}
.chat-av{width:48px;height:48px;border-radius:12px;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.18);display:flex;align-items:center;justify-content:center}
.chat-name{font-weight:800;color:#fff;font-size:1.05rem}
.chat-status{font-size:0.73rem;color:rgba(255,255,255,.5);margin-top:2px}
.chat-msgs{padding:1.2rem;min-height:400px;max-height:500px;overflow-y:auto;display:flex;flex-direction:column;gap:12px;background:#fbfdff}
.brow-bot{display:flex;align-items:flex-end;gap:8px}
.brow-usr{display:flex;justify-content:flex-end}
.bot-av{width:26px;height:26px;min-width:26px;border-radius:8px;background:#0770e3;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.bub-bot{background:#fff;border:1px solid #eef2f6;color:#1e293b;border-radius:14px 14px 14px 4px;padding:.65rem 1rem;max-width:80%;font-size:.875rem;line-height:1.55}
.bub-usr{background:#0770e3;color:#fff;border-radius:14px 14px 4px 14px;padding:.65rem 1rem;max-width:74%;font-size:.875rem;line-height:1.55}
.typing span{display:inline-block;width:5px;height:5px;border-radius:50%;background:#0770e3;margin:0 2px;animation:db .8s infinite}
.typing span:nth-child(2){animation-delay:.15s}.typing span:nth-child(3){animation-delay:.3s}
@keyframes db{0%,80%,100%{transform:translateY(0)}40%{transform:translateY(-5px)}}
.chat-input-row{padding:12px;border-top:1px solid #e6e6e6;display:flex;gap:8px;align-items:center}
#chat-input{flex:1;border:1.5px solid #e6e6e6;border-radius:100px;padding:10px 18px;font-size:.875rem;outline:none;font-family:inherit}
#chat-input:focus{border-color:#0770e3}
#chat-send{background:#0770e3;color:#fff;border:none;border-radius:100px;padding:10px 22px;font-family:inherit;font-weight:700;font-size:.82rem;cursor:pointer}
#chat-send:disabled{opacity:.4;cursor:default}
.limit-banner{background:#fff8ee;border-top:1px solid rgba(245,158,11,.15);padding:12px 16px;text-align:center;font-size:.78rem;color:#f59e0b;font-weight:600;display:none}
@media(max-width:500px){.chat-container{margin:0;border-radius:0;border:none;box-shadow:none}.chat-msgs{min-height:60vh;max-height:60vh}}
</style>
</head>
<body>
<div class="top-bar">
  <a href="/">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="#0770e3" stroke-width="2.5" stroke-linecap="round"/></svg>
    Retour à Midzo Flight
  </a>
  <span style="font-weight:800;color:#111236;font-size:1rem;">MIDZO</span>
  <span></span>
</div>

<div class="chat-container">
  <div class="chat-header">
    <div class="chat-av"><svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="4" stroke="rgba(255,255,255,.8)" stroke-width="2"/><path d="M4 22c0-4.418 3.582-8 8-8s8 3.582 8 8" stroke="rgba(255,255,255,.8)" stroke-width="2" stroke-linecap="round"/></svg></div>
    <div>
      <div class="chat-name">Sofia · Conseillère voyage IA</div>
      <div class="chat-status">Disponible 24/7 · Midzo Flight</div>
    </div>
  </div>
  <div id="chat-msgs"></div>
  <div class="limit-banner" id="limit-banner">⚠️ Messages gratuits épuisés aujourd'hui. Passez à l'illimité pour continuer.</div>
  <div class="chat-input-row">
    <input type="text" id="chat-input" placeholder="Posez votre question voyage..." autocomplete="off">
    <button id="chat-send">Envoyer</button>
  </div>
</div>

<script>
let msgCount = parseInt(localStorage.getItem('sofia_msgs')||'0');
const MAX_FREE = 10;
let lang = 'fr';
let chatCtx = [];

const msgsDiv = document.getElementById('chat-msgs');
const inputEl  = document.getElementById('chat-input');
const sendBtn  = document.getElementById('chat-send');
const limitBan = document.getElementById('limit-banner');

function addBotMsg(text) {
  const row = document.createElement('div'); row.className = 'brow-bot';
  row.innerHTML = `<div class="bot-av"><svg width="11" height="11" viewBox="0 0 24 24" fill="none"><path d="M21 16v-2l-8-5V3.5A1.5 1.5 0 0 0 11.5 2h0A1.5 1.5 0 0 0 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5l8 2.5Z" fill="white"/></svg></div><div class="bub-bot">${text}</div>`;
  msgsDiv.appendChild(row); msgsDiv.scrollTop = msgsDiv.scrollHeight;
}
function addUserMsg(text) {
  const row = document.createElement('div'); row.className = 'brow-usr';
  row.innerHTML = `<div class="bub-usr">${text}</div>`;
  msgsDiv.appendChild(row); msgsDiv.scrollTop = msgsDiv.scrollHeight;
}
function showTyping() {
  const row = document.createElement('div'); row.className = 'brow-bot'; row.id = 'typing';
  row.innerHTML = `<div class="bot-av"><svg width="11" height="11" viewBox="0 0 24 24" fill="none"><path d="M21 16v-2l-8-5V3.5A1.5 1.5 0 0 0 11.5 2h0A1.5 1.5 0 0 0 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5l8 2.5Z" fill="white"/></svg></div><div class="bub-bot"><div class="typing"><span></span><span></span><span></span></div></div>`;
  msgsDiv.appendChild(row); msgsDiv.scrollTop = msgsDiv.scrollHeight;
}
function hideTyping() { document.getElementById('typing')?.remove(); }

function checkLimit() {
  const today = new Date().toDateString();
  const stored = localStorage.getItem('sofia_date');
  if (stored !== today) { msgCount = 0; localStorage.setItem('sofia_date', today); }
  if (msgCount >= MAX_FREE) {
    limitBan.style.display = 'block';
    inputEl.disabled = true;
    sendBtn.disabled = true;
    return false;
  }
  limitBan.style.display = 'none';
  return true;
}

async function handleSend() {
  const text = inputEl.value.trim();
  if (!text || !checkLimit()) return;
  
  addUserMsg(text);
  chatCtx.push({role:'user',content:text});
  inputEl.value = '';
  msgCount++;
  localStorage.setItem('sofia_msgs', msgCount);
  checkLimit();
  
  showTyping();
  try {
    const r = await fetch('/api/chat', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        message:text,
        context:chatCtx.slice(-10),
        lang,
        mode:'conseil' // Mode conseil voyage pur
      })
    });
    hideTyping();
    if (r.ok) {
      const d = await r.json();
      if (d.reply) {
        addBotMsg(d.reply);
        chatCtx.push({role:'assistant',content:d.reply});
      }
    } else {
      addBotMsg('Désolé, je ne peux pas répondre maintenant. Réessayez dans un instant.');
    }
  } catch(e) {
    hideTyping();
    addBotMsg('Problème de connexion. Vérifiez votre internet et réessayez.');
  }
}

function init() {
  addBotMsg('Bonjour ! 👋 Je suis Sofia, votre conseillère voyage. Demandez-moi conseil : destinations, meilleures périodes, astuces, budget… Je suis là pour vous aider à préparer votre voyage !');
  chatCtx.push({role:'assistant',content:'Bonjour ! Je suis Sofia, votre conseillère voyage.'});
  checkLimit();
}

sendBtn.onclick = handleSend;
inputEl.onkeypress = e => { if (e.key==='Enter') { e.preventDefault(); handleSend(); } };
init();
</script>
</body>
</html>
