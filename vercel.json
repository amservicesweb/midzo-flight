{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/sofia", "dest": "/sofia.html" },
    { "src": "/sofia.html", "dest": "/sofia.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
